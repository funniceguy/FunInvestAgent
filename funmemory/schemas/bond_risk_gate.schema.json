{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bond_risk_gate.schema.json",
  "title": "Bond Credit Liquidity Risk Gate",
  "type": "object",
  "additionalProperties": false,
  "required": ["instrument_id", "as_of", "categories", "weighted_score", "unknown_count", "critical_blockers", "stress_losses", "decision", "new_order_allowed", "evidence_ids"],
  "properties": {
    "instrument_id": {"type": "string", "minLength": 1},
    "as_of": {"type": "string", "minLength": 1},
    "categories": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": ["id", "score", "minimum", "passed", "evidence_ids"],
        "properties": {
          "id": {"enum": ["terms_identification", "credit_capacity", "ytw_call_prepayment", "duration_convexity", "liquidity_execution", "concentration_spread", "fx_hedge_tax", "expression_traceability"]},
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "minimum": {"type": "number", "minimum": 0, "maximum": 100},
          "passed": {"type": "boolean"},
          "evidence_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "weighted_score": {"type": "number", "minimum": 0, "maximum": 100},
    "unknown_count": {"type": "integer", "minimum": 0},
    "critical_blockers": {"type": "array", "items": {"type": "string"}},
    "stress_losses": {
      "type": "object",
      "required": ["rate_up", "spread_widening", "liquidity_sale", "combined"],
      "properties": {
        "rate_up": {"type": "number"},
        "spread_widening": {"type": "number"},
        "liquidity_sale": {"type": "number"},
        "fx_adverse": {"type": ["number", "null"]},
        "combined": {"type": "number"}
      }
    },
    "decision": {"enum": ["clear", "conditional", "watch_only", "blocked"]},
    "new_order_allowed": {"type": "boolean"},
    "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "repairs": {"type": "array", "items": {"type": "string"}}
  }
}

