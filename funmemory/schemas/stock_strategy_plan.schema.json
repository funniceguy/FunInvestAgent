{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://funinvestagent.local/schemas/stock_strategy_plan.schema.json",
  "title": "StockStrategyPlan",
  "type": "object",
  "required": [
    "strategy_id",
    "created_at",
    "base_currency",
    "scope",
    "capital_preservation_recovery_gate",
    "cash_deposit_bond_comparison",
    "market_regime",
    "cross_market_outcome_audit",
    "product_quote_packet",
    "psychology_gate",
    "capital_allocation",
    "short_term_plan",
    "value_investing_plan",
    "risk_controls",
    "verification_contract",
    "source_ids",
    "review_schedule"
  ],
  "properties": {
    "strategy_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "base_currency": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": [
        "markets",
        "strategy_modes",
        "capital_basis"
      ],
      "properties": {
        "markets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strategy_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "short_term",
              "aggressive_short_term",
              "forward_outlook",
              "cross_market_outcome_audit",
              "forecast_learning_loop",
              "predictive_calibration",
              "failure_postmortem",
              "macro_causal_matrix",
              "market_integrity_causal_attribution",
              "supply_overhang_order_flow",
              "momentum_rotation_cycle",
              "value_investing",
              "long_term_total_return",
              "covered_call_income",
              "cash_deposit_substitution"
            ]
          }
        },
        "capital_basis": {
          "type": "string",
          "enum": [
            "actual_amount",
            "percentage_only"
          ]
        }
      }
    },
    "market_regime": {
      "type": "string",
      "enum": [
        "defensive",
        "neutral",
        "favorable",
        "unknown"
      ]
    },
    "market_integrity_causal_attribution": {
      "$ref": "stock_market_integrity_causal_attribution.schema.json"
    },
    "capital_preservation_recovery_gate": {
      "$ref": "stock_capital_preservation_recovery_gate.schema.json"
    },
    "cash_deposit_bond_comparison": {
      "$ref": "cash_deposit_bond_comparison.schema.json"
    },
    "psychology_gate": {
      "$ref": "https://funinvestagent.local/schemas/stock_psychology_gate.schema.json"
    },
    "leverage_risk_gate": {
      "$ref": "https://funinvestagent.local/schemas/stock_leverage_risk_gate.schema.json"
    },
    "cross_market_outcome_audit": {
      "$ref": "https://funinvestagent.local/schemas/stock_cross_market_outcome_audit.schema.json"
    },
    "supply_overhang_order_flow": {
      "type": "array",
      "items": {
        "$ref": "https://funinvestagent.local/schemas/stock_supply_overhang_order_flow.schema.json"
      }
    },
    "momentum_rotation_cycles": {
      "type": "array",
      "items": {
        "$ref": "https://funinvestagent.local/schemas/stock_momentum_rotation_cycle.schema.json"
      }
    },
    "forecast_learning_loop": {
      "type": "object",
      "required": [
        "applied",
        "decision",
        "lookback_start",
        "lookback_end",
        "prior_report_count",
        "prediction_count",
        "success_count",
        "failure_count",
        "unknown_count",
        "score_adjustments"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "decision": {
          "type": "string",
          "enum": [
            "calibrated",
            "conditional",
            "insufficient_sample",
            "blocked",
            "not_applicable"
          ]
        },
        "lookback_start": {
          "type": "string",
          "format": "date"
        },
        "lookback_end": {
          "type": "string",
          "format": "date"
        },
        "prior_report_count": {
          "type": "integer",
          "minimum": 0
        },
        "prediction_count": {
          "type": "integer",
          "minimum": 0
        },
        "success_count": {
          "type": "integer",
          "minimum": 0
        },
        "partial_success_count": {
          "type": "integer",
          "minimum": 0
        },
        "failure_count": {
          "type": "integer",
          "minimum": 0
        },
        "unknown_count": {
          "type": "integer",
          "minimum": 0
        },
        "reviewed_reports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "report_date"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "report_date": {
                "type": "string"
              },
              "prediction_count": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "reviewed_predictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "prediction_id",
              "target",
              "classification"
            ],
            "properties": {
              "prediction_id": {
                "type": "string"
              },
              "target": {
                "type": "string"
              },
              "source_report": {
                "type": "string"
              },
              "expected_direction": {
                "type": "string"
              },
              "actual_outcome": {
                "type": "string"
              },
              "classification": {
                "type": "string",
                "enum": [
                  "success",
                  "partial_success",
                  "failure",
                  "unknown"
                ]
              },
              "root_cause": {
                "type": "string"
              },
              "rule_change": {
                "type": "string"
              }
            }
          }
        },
        "recurring_failure_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "data_staleness",
              "expectation_misread",
              "hidden_expectation_gap",
              "flow_misread",
              "fx_rate_mismatch",
              "macro_policy_misread",
              "event_timing_error",
              "intraday_timing_error",
              "psychology_error",
              "execution_error",
              "random_outcome"
            ]
          }
        },
        "retained_success_rules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "score_adjustments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "category",
              "previous_minimum_score",
              "adjusted_minimum_score",
              "reason"
            ],
            "properties": {
              "category": {
                "type": "string"
              },
              "previous_minimum_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "adjusted_minimum_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "reason": {
                "type": "string"
              },
              "applies_for_next_strategy_count": {
                "type": "integer",
                "minimum": 1,
                "maximum": 3
              }
            }
          }
        },
        "applied_to_current_strategy": {
          "type": "boolean"
        },
        "critical_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "forecast_failure_postmortem": {
      "type": "object",
      "required": [
        "applied",
        "decision",
        "severity",
        "root_causes",
        "rule_changes"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "decision": {
          "type": "string",
          "enum": [
            "proceed_possible",
            "conditional_review",
            "defer",
            "stop_recommended",
            "not_applicable"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "minor",
            "moderate",
            "severe",
            "critical",
            "not_applicable"
          ]
        },
        "previous_strategy_id": {
          "type": "string"
        },
        "actual_outcome_summary": {
          "type": "string"
        },
        "first_warning_signal": {
          "type": "string"
        },
        "missed_leading_indicators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "root_causes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "cause",
              "score"
            ],
            "properties": {
              "cause": {
                "type": "string"
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 10
              },
              "evidence": {
                "type": "string"
              },
              "new_rule": {
                "type": "string"
              }
            }
          }
        },
        "rule_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "forward_outlook_research": {
      "type": "object",
      "required": [
        "applied",
        "horizon",
        "decision",
        "score",
        "source_count",
        "evidence_card_count",
        "domains_covered",
        "critical_blockers"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "horizon": {
          "type": "string",
          "enum": [
            "next_week",
            "1_month",
            "quarter",
            "6_12_month",
            "unknown"
          ]
        },
        "searched_at": {
          "type": "string",
          "format": "date-time"
        },
        "decision": {
          "type": "string",
          "enum": [
            "outlook_usable",
            "conditional_outlook",
            "watch_only",
            "blocked",
            "not_applicable"
          ]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "source_count": {
          "type": "integer",
          "minimum": 0
        },
        "primary_source_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_card_count": {
          "type": "integer",
          "minimum": 0
        },
        "domains_covered": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "geopolitics",
              "macro",
              "rates_liquidity",
              "fx",
              "commodities",
              "investor_flows",
              "sentiment",
              "event_calendar",
              "earnings"
            ]
          }
        },
        "base_scenario": {
          "type": "string"
        },
        "bull_scenario": {
          "type": "string"
        },
        "bear_scenario": {
          "type": "string"
        },
        "strategy_direction": {
          "type": "string",
          "enum": [
            "attack",
            "selective_attack",
            "neutral",
            "defensive",
            "stop",
            "unknown"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "invalidation_conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "critical_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "predictive_calibration": {
      "type": "object",
      "required": [
        "applied",
        "horizon",
        "decision",
        "score",
        "predictions",
        "critical_blockers"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "horizon": {
          "type": "string",
          "enum": [
            "intraday",
            "next_day",
            "next_week",
            "1_month",
            "unknown"
          ]
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "decision": {
          "type": "string",
          "enum": [
            "prediction_usable",
            "conditional_prediction",
            "watch_only",
            "prediction_blocked",
            "not_applicable"
          ]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "data_points": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "data_as_of",
              "source_id",
              "direction_contribution"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "latest_value": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "one_day_change": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "three_day_change": {
                "type": [
                  "number",
                  "string"
                ]
              },
              "data_as_of": {
                "type": "string"
              },
              "source_id": {
                "type": "string"
              },
              "direction_contribution": {
                "type": "string",
                "enum": [
                  "up",
                  "range",
                  "down",
                  "mixed",
                  "neutral"
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low",
                  "unknown"
                ]
              }
            }
          }
        },
        "predictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "prediction_id",
              "target",
              "up_probability",
              "range_probability",
              "down_probability",
              "verification_time",
              "actual_judgement_basis"
            ],
            "properties": {
              "prediction_id": {
                "type": "string"
              },
              "target": {
                "type": "string"
              },
              "up_probability": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "range_probability": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "down_probability": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "expected_range": {
                "type": "string"
              },
              "supporting_data": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "conflicting_data": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "verification_time": {
                "type": "string"
              },
              "actual_judgement_basis": {
                "type": "string"
              },
              "error_calculation": {
                "type": "string"
              }
            }
          }
        },
        "critical_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "product_quote_packet": {
      "type": "object",
      "required": [
        "quote_status",
        "products"
      ],
      "properties": {
        "quote_status": {
          "type": "string",
          "enum": [
            "real_time",
            "delayed",
            "stale",
            "unavailable"
          ]
        },
        "quote_checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "display_name",
              "product_name",
              "symbol",
              "exchange",
              "currency",
              "product_type",
              "data_as_of",
              "quote_status",
              "liquidity_decision",
              "execution_decision"
            ],
            "properties": {
              "display_name": {
                "type": "string",
                "description": "Human-readable security display name, e.g. 한글명/Official Full Name (TICKER)."
              },
              "product_name": {
                "type": "string"
              },
              "symbol": {
                "type": "string"
              },
              "isin": {
                "type": "string"
              },
              "exchange": {
                "type": "string"
              },
              "currency": {
                "type": "string"
              },
              "product_type": {
                "type": "string",
                "enum": [
                  "stock",
                  "etf",
                  "etn",
                  "cash_like",
                  "inverse",
                  "leveraged",
                  "other"
                ]
              },
              "data_as_of": {
                "type": "string"
              },
              "quote_status": {
                "type": "string",
                "enum": [
                  "real_time",
                  "delayed",
                  "stale",
                  "unavailable"
                ]
              },
              "current_or_last_price": {
                "type": "number"
              },
              "bid_price": {
                "type": "number"
              },
              "ask_price": {
                "type": "number"
              },
              "bid_size": {
                "type": "number"
              },
              "ask_size": {
                "type": "number"
              },
              "spread_percent": {
                "type": "number"
              },
              "volume": {
                "type": "number"
              },
              "turnover": {
                "type": "number"
              },
              "average_turnover_20d": {
                "type": "number"
              },
              "nav_or_iopv": {
                "type": "number"
              },
              "premium_discount_percent": {
                "type": "number"
              },
              "expense_ratio_percent": {
                "type": "number"
              },
              "leverage_multiple": {
                "type": "number"
              },
              "liquidity_decision": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low",
                  "blocked"
                ]
              },
              "execution_decision": {
                "type": "string",
                "enum": [
                  "actionable",
                  "conditional",
                  "watch_only",
                  "blocked"
                ]
              },
              "source_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "macro_causal_factor_matrix": {
      "type": "object",
      "required": [
        "applied",
        "decision",
        "candidates"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "decision": {
          "type": "string",
          "enum": [
            "efficiency_leader",
            "efficient_tactical",
            "watch_only",
            "blocked",
            "not_applicable"
          ]
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "display_name",
              "symbol",
              "efficiency_score",
              "decision"
            ],
            "properties": {
              "display_name": {
                "type": "string",
                "description": "Human-readable candidate display name, e.g. 한글명/Official Full Name (TICKER)."
              },
              "symbol": {
                "type": "string"
              },
              "factor_sensitivity": {
                "type": "object",
                "additionalProperties": {
                  "type": "number",
                  "minimum": -5,
                  "maximum": 5
                }
              },
              "strong_tailwind_count": {
                "type": "integer",
                "minimum": 0
              },
              "strong_headwind_count": {
                "type": "integer",
                "minimum": 0
              },
              "efficiency_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "decision": {
                "type": "string",
                "enum": [
                  "efficiency_leader",
                  "efficient_tactical",
                  "watch_only",
                  "blocked"
                ]
              },
              "suitable_strategy": {
                "type": "string",
                "enum": [
                  "short_term",
                  "swing",
                  "value_investing",
                  "defensive",
                  "excluded",
                  "unknown"
                ]
              },
              "invalidation_conditions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "critical_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "quality_value_screening": {
      "type": "object",
      "required": [
        "applied",
        "candidates"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "screened_at": {
          "type": "string",
          "format": "date-time"
        },
        "market_or_sector_scope": {
          "type": "string"
        },
        "lead_sector_hypothesis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "display_name",
              "symbol",
              "decision",
              "score",
              "rank_eligible",
              "risk_signal_count",
              "value_trap_flag"
            ],
            "properties": {
              "display_name": {
                "type": "string",
                "description": "Human-readable candidate display name, e.g. 한글명/Official Full Name (TICKER)."
              },
              "symbol": {
                "type": "string"
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "decision": {
                "type": "string",
                "enum": [
                  "core_watch",
                  "conditional_watch",
                  "needs_more_verification",
                  "exception_watch",
                  "rank_excluded_multi_risk",
                  "excluded"
                ]
              },
              "rank_eligible": {
                "type": "boolean"
              },
              "operating_margin_percent": {
                "type": "number"
              },
              "profitability_metric": {
                "type": "string"
              },
              "risk_signal_count": {
                "type": "integer",
                "minimum": 0,
                "maximum": 7
              },
              "risk_signals": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "low_operating_margin",
                    "low_roe",
                    "weak_operating_cash_flow",
                    "high_debt_or_interest_burden",
                    "no_growth_catalyst",
                    "no_shareholder_return",
                    "weak_institutional_or_foreign_flow"
                  ]
                }
              },
              "exception_candidate": {
                "type": "boolean"
              },
              "value_trap_flag": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              },
              "growth_basis": {
                "type": "string"
              },
              "capital_efficiency_basis": {
                "type": "string"
              },
              "valuation_basis": {
                "type": "string"
              },
              "catalysts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "source_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "critical_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "aggressive_short_term_probability": {
      "type": "object",
      "required": [
