{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "crypto_prediction_ledger.schema.json",
  "title": "Crypto Prediction Ledger Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["prediction_id", "created_at", "asset_display_name", "exchange", "quote_currency", "horizon", "probabilities", "expected_range", "verification_at", "success_rule", "failure_rule", "status"],
  "properties": {
    "prediction_id": {"type": "string", "minLength": 1},
    "parent_prediction_id": {"type": ["string", "null"]},
    "created_at": {"type": "string", "format": "date-time"},
    "asset_display_name": {"type": "string", "minLength": 1},
    "exchange": {"type": "string", "minLength": 1},
    "quote_currency": {"type": "string", "minLength": 1},
    "horizon": {"type": "string", "minLength": 1},
    "probabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["up", "flat", "down"],
      "properties": {
        "up": {"type": "number", "minimum": 0, "maximum": 1},
        "flat": {"type": "number", "minimum": 0, "maximum": 1},
        "down": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "expected_range": {"type": "object", "required": ["low", "high"], "properties": {"low": {"type": "number"}, "high": {"type": "number"}}},
    "verification_at": {"type": "string", "format": "date-time"},
    "success_rule": {"type": "string", "minLength": 1},
    "failure_rule": {"type": "string", "minLength": 1},
    "status": {"enum": ["open", "success", "failure", "flat", "matured_unscored", "invalidated"]},
    "forecast_outcome": {"type": ["string", "null"]},
    "execution_outcome": {"type": ["string", "null"]},
    "risk_outcome": {"type": ["string", "null"]},
    "evidence_ids": {"type": "array", "items": {"type": "string"}}
  }
}

