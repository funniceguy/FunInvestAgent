{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cash_deposit_bond_comparison.schema.json",
  "title": "Cash Deposit Bond Comparison Gate",
  "type": "object",
  "additionalProperties": false,
  "required": ["comparison_id", "as_of", "horizon_bucket", "base_currency", "cash_need_dates", "candidates", "categories", "weighted_score", "critical_blockers", "decision", "new_allocation_allowed", "evidence_ids"],
  "properties": {
    "comparison_id": {"type": "string", "minLength": 1},
    "as_of": {"type": "string", "minLength": 1},
    "horizon_bucket": {"enum": ["under_1y_uncertain", "one_to_three_years", "over_3y_stability"]},
    "base_currency": {"type": "string", "minLength": 3, "maxLength": 3},
    "cash_need_dates": {"type": "array", "items": {"type": "string"}},
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["product_id", "product_type", "protection_status", "liquidity_status", "net_annualized_return", "stress_cash_available", "eligible", "exclusion_reasons"],
        "properties": {
          "product_id": {"type": "string"},
          "product_type": {"type": "string"},
          "protection_status": {"enum": ["protected", "not_protected", "partial", "unknown"]},
          "liquidity_status": {"enum": ["matched", "conditional", "mismatched", "unknown"]},
          "net_annualized_return": {"type": ["number", "null"]},
          "stress_cash_available": {"type": ["number", "null"]},
          "bond_excess_return": {"type": ["number", "null"]},
          "risk_uncertainty_buffer": {"type": ["number", "null"], "minimum": 0},
          "eligible": {"type": "boolean"},
          "exclusion_reasons": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "categories": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "required": ["id", "score", "minimum", "passed", "evidence_ids"],
        "properties": {
          "id": {"enum": ["identity_protection_limit", "cash_need_liquidity", "after_tax_cashflow", "same_maturity_bond_comparison", "reinvestment_rate_inflation", "condition_operability", "expression_traceability"]},
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "minimum": {"type": "number", "minimum": 0, "maximum": 100},
          "passed": {"type": "boolean"},
          "evidence_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "weighted_score": {"type": "number", "minimum": 0, "maximum": 100},
    "critical_blockers": {"type": "array", "items": {"type": "string"}},
    "decision": {"enum": ["parking_preferred", "deposit_preferred", "installment_preferred", "bond_preferred", "mixed_ladder", "no_eligible_product"]},
    "new_allocation_allowed": {"type": "boolean"},
    "next_check_at": {"type": ["string", "null"]},
    "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}

